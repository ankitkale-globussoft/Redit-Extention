{
  "manifest_version": 3,
  "name": "Reddit Scraper Pro",
  "version": "1.0",
  "description": "Scrape Reddit posts, comments, and replies into CSV.",
  "permissions": ["activeTab", "scripting", "downloads", "sidePanel"],
  "action": {
    "default_title": "Open Reddit Scraper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.reddit.com/*"],
      "js": ["utils.js", "content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["utils.js"],
      "matches": ["https://*.reddit.com/*"]
    }
  ]
}
